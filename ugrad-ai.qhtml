<!-- beyondBINARY quantum-prefixed | uvspeed | {n, +1, -n, +0, 0, -1, +n, +2, -0, +3, 1} -->
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#e9dfcd" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <title>ugrad.ai | Quantum-Centric Communication Cycle Research</title>
  <link rel="manifest" href="manifest.webmanifest" />
  <script src="quantum-prefixes.js"></script>
  <style>
    :root{
      --bg:#ece3d3;
      --bg2:#f2e9d9;
      --ink:#3f3528;
      --muted:#6d6254;
      --accent:#ad8550;
      --cyan:#9aa293;
      --edge:transparent;
      --card:#f6eedf;
      --dot:rgba(150,122,85,.18);
      --mono:"SF Mono","Cascadia Code","Menlo",monospace;
      --sans:"Inter","Avenir Next","Segoe UI",system-ui,sans-serif;
      --hero-badge-max-width:272px;
      --hero-badge-padding-y:8px;
      --hero-badge-padding-x:10px;
      --hero-badge-gap:8px;
      --hero-badge-radius:0px;
      --hero-badge-border:2px;
      --hero-badge-font-size:54px;
      --hero-badge-line-width:40px;
      --hero-badge-line-thickness:3px;
      --hero-badge-orb-size:10px;
      --hero-badge-caption-size:12px;
      --hero-badge-caption-spacing:.005em;
    }
    *{box-sizing:border-box}
    html,body{margin:0;background:var(--bg);color:var(--ink);font-family:var(--sans);}
    body{
      min-height:100vh;
      background:linear-gradient(180deg, #f4f7fc 0%, #eef3fb 58%, #e8eef8 100%);
      position:relative;
      overflow-x:hidden;
      isolation:isolate;
    }
    body::before{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      opacity:.48;
      background-image:
        radial-gradient(72% 64% at 14% 20%, rgba(49,171,255,.34) 0%, rgba(49,171,255,.16) 35%, rgba(49,171,255,0) 72%),
        radial-gradient(68% 62% at 86% 18%, rgba(154,126,255,.44) 0%, rgba(154,126,255,.2) 36%, rgba(154,126,255,0) 74%),
        radial-gradient(80% 74% at 56% 80%, rgba(130,196,255,.24) 0%, rgba(130,196,255,.1) 38%, rgba(130,196,255,0) 78%);
      background-repeat:no-repeat;
      background-size:180% 120%, 170% 120%, 200% 140%;
      background-position:8% 6%, 94% 10%, 50% 96%;
      animation:bg-shift-main 32s ease-in-out infinite alternate;
      will-change:background-position, transform;
      z-index:0;
    }
    body::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      opacity:.34;
      background-image:
        radial-gradient(64% 56% at 24% 78%, rgba(61,185,255,.22) 0%, rgba(61,185,255,.1) 38%, rgba(61,185,255,0) 76%),
        radial-gradient(60% 56% at 88% 70%, rgba(172,138,255,.36) 0%, rgba(172,138,255,.16) 34%, rgba(172,138,255,0) 72%);
      background-position:10% 80%, 90% 18%;
      background-repeat:no-repeat;
      background-size:170% 120%, 180% 130%;
      animation:bg-shift-accent 40s ease-in-out infinite alternate-reverse;
      will-change:background-position, transform;
      z-index:0;
    }
    @keyframes bg-shift-main{
      0%{
        transform:translate3d(0,0,0) scale(1);
        background-position:8% 6%, 94% 10%, 50% 96%;
      }
      50%{
        transform:translate3d(-1.2%,1.4%,0) scale(1.02);
        background-position:6% 9%, 97% 12%, 52% 93%;
      }
      100%{
        transform:translate3d(1.6%,-1.4%,0) scale(1.03);
        background-position:10% 4%, 92% 8%, 48% 98%;
      }
    }
    @keyframes bg-shift-accent{
      0%{
        transform:translate3d(0,0,0) scale(1);
        background-position:10% 80%, 90% 18%;
      }
      100%{
        transform:translate3d(-1.8%,1.5%,0) scale(1.04);
        background-position:7% 83%, 93% 15%;
      }
    }
    .page{max-width:1180px;margin:0 auto;padding:24px 22px 56px;position:relative;z-index:1;}
    .page > *{position:relative;z-index:1;}
    .reactive-dots{
      position:absolute;
      top:0;
      left:0;
      right:0;
      height:min(72vh,840px);
      width:100%;
      z-index:0;
      pointer-events:none;
      opacity:.96;
      filter:contrast(1.14) brightness(1.1);
      mask-image:linear-gradient(180deg, rgba(0,0,0,.98) 0%, rgba(0,0,0,.94) 56%, rgba(0,0,0,.42) 78%, rgba(0,0,0,0) 100%);
      -webkit-mask-image:linear-gradient(180deg, rgba(0,0,0,.98) 0%, rgba(0,0,0,.94) 56%, rgba(0,0,0,.42) 78%, rgba(0,0,0,0) 100%);
    }
    .hero{
      box-sizing:content-box;
      border:none;
      border-radius:12px;
      background:none !important;
      background-color:transparent !important;
      background-image:none !important;
      padding:24px 22px;
      box-shadow:none;
      text-align:center;
    }
    .top-menu{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      padding:8px 12px;
      margin:0 calc(50% - 50vw) 10px;
      width:auto;
      border:1px solid rgba(198,206,222,.85);
      border-radius:0;
      background:#ffffff;
      box-shadow:0 1px 0 rgba(16,24,40,.03);
      position:sticky;
      top:0;
      z-index:40;
    }
    .top-menu .brand{
      color:#3f3223;
      font:700 10px/1 var(--mono);
      letter-spacing:.07em;
      text-transform:uppercase;
      white-space:nowrap;
    }
    .top-menu .items{
      display:flex;
      flex-wrap:wrap;
      justify-content:flex-end;
      gap:6px;
    }
    .top-menu .items a{
      color:#4f678d;
      text-decoration:none;
      font:700 10px/1 var(--mono);
      letter-spacing:.03em;
      text-transform:uppercase;
      border:1px solid rgba(122,162,219,.35);
      border-radius:999px;
      padding:5px 8px;
      background:rgba(246,250,255,.92);
    }
    .top-menu .items a:hover{
      background:rgba(235,244,255,.96);
      border-color:rgba(94,142,214,.55);
    }
    main.page > header.hero{
      background:transparent !important;
      background-color:transparent !important;
      background-image:none !important;
    }
    .eyebrow{
      font:700 12px/1 var(--mono);
      letter-spacing:.18em;
      color:#9c7441;
      margin:0 0 8px 0;
      text-transform:uppercase;
    }
    .hero-formula-wrap{
      width:min(100%, var(--hero-badge-max-width));
      margin:0 auto 6px auto;
      text-align:center;
    }
    .hero-formula-box{
      width:100%;
      background:transparent;
      box-shadow:none;
    }
    .hero-formula-svg{
      display:block;
      width:100%;
      height:auto;
      overflow:visible;
    }
    .hero-eq{
      margin:0 0 8px 0;
      color:#4a3a28;
      display:inline-block;
      position:relative;
      padding:4px 14px;
      font:700 24px/1.12 "Times New Roman", Georgia, serif;
      letter-spacing:.01em;
      text-shadow:0 1px 0 rgba(255,255,255,.88), 0 0 8px rgba(255,255,255,.36);
    }
    .hero-eq::before{
      content:"";
      position:absolute;
      inset:-10px -20px;
      border-radius:999px;
      background:radial-gradient(circle at 50% 50%,
        rgba(255,255,255,.88) 0%,
        rgba(255,255,255,.68) 36%,
        rgba(255,255,255,.28) 68%,
        rgba(255,255,255,0) 100%);
      z-index:-1;
      filter:blur(1.4px);
      pointer-events:none;
    }
    .title{
      margin:0;
      font-weight:700;
      letter-spacing:.01em;
      line-height:1.1;
      font-size:clamp(25px,4vw,42px);
      color:#443624;
    }
    .subtitle{
      margin:10px 0 0 0;
      color:var(--muted);
      font-size:14px;
      max-width:860px;
      margin-left:auto;
      margin-right:auto;
    }
    .brand-row{
      margin-top:14px;
      display:flex;
      flex-wrap:wrap;
      gap:8px;
      font:600 11px/1 var(--mono);
      color:#7f715e;
      justify-content:center;
    }
    .pill{
      border:none;
      border-radius:10px;
      padding:6px 10px;
      background:transparent;
    }
    .layout{
      margin-top:20px;
      display:grid;
      grid-template-columns:minmax(0,1fr) 320px;
      gap:24px;
      align-items:start;
    }
    .paper{
      border:none;
      border-radius:12px;
      background:transparent;
      padding:16px 16px 18px;
    }
    .paper h2{
      margin:0 0 10px 0;
      color:#3f3223;
      letter-spacing:.02em;
      font-size:26px;
    }
    .paper h3{
      margin:24px 0 10px 0;
      padding-top:14px;
      border-top:1px solid rgba(157,121,76,.24);
      color:#4c3f31;
      font-size:18px;
    }
    .paper p{
      margin:0 0 12px 0;
      color:#4f4539;
      text-align:left;
      line-height:1.72;
      font-size:15px;
    }
    .exec{
      margin:12px 0 16px;
      padding:12px 14px;
      border:1px solid rgba(157,121,76,.25);
      border-radius:12px;
      background:rgba(255,255,255,.36);
    }
    .exec .kicker{
      margin:0 0 8px 0;
      color:#7d6140;
      font:700 11px/1 var(--mono);
      letter-spacing:.08em;
      text-transform:uppercase;
    }
    .exec .exec-eq-top{
      margin:0 0 8px 0;
      color:#5e4a33;
      font:600 13px/1.35 var(--mono);
      letter-spacing:.01em;
      display:inline-block;
      background:rgba(255,255,255,.94);
      border-radius:6px;
      padding:2px 6px;
      max-width:100%;
      overflow-wrap:anywhere;
    }
    .exec .exec-eq-link{
      margin:0 0 8px 0;
      width:fit-content;
      max-width:100%;
      color:#5a6f8f;
      font:700 10px/1.25 var(--mono);
      letter-spacing:.03em;
      background:rgba(245,249,255,.92);
      border:1px solid rgba(122,162,219,.32);
      border-radius:6px;
      padding:2px 6px;
      overflow-wrap:anywhere;
    }
    .exec ul{
      margin:0;
      padding-left:18px;
      display:grid;
      gap:6px;
    }
    .exec li{
      color:#4d4234;
      font-size:14px;
      line-height:1.45;
    }
    .exec.eq-walk{
      margin:8px 0 14px;
      padding:10px 12px;
      background:rgba(255,255,255,.42);
    }
    .exec.eq-walk .kicker{
      letter-spacing:.06em;
      margin-bottom:7px;
    }
    .exec.eq-walk ul{
      gap:5px;
    }
    .exec.eq-walk li{
      font-size:13px;
      line-height:1.4;
    }
    .eq{
      border:none;
      background:transparent;
      border-radius:10px;
      padding:8px 10px;
      margin:8px 0;
    }
    .eq .sym{
      color:#4c3e2f;
      font:700 13px/1.45 var(--mono);
      display:block;
      width:fit-content;
      max-width:100%;
      background:rgba(255,255,255,.94);
      border-radius:6px;
      padding:2px 6px;
      overflow-wrap:anywhere;
    }
    .eq .plain{
      color:#7a6f62;
      font:600 11px/1.35 var(--mono);
      display:block;
      margin-top:4px;
      width:fit-content;
      max-width:100%;
      background:rgba(238,241,246,.96);
      border-radius:6px;
      padding:2px 6px;
      overflow-wrap:anywhere;
    }
    .eq .eq-link{
      display:block;
      width:fit-content;
      max-width:100%;
      margin-top:5px;
      color:#5a6f8f;
      font:700 10px/1.25 var(--mono);
      letter-spacing:.02em;
      background:rgba(245,249,255,.92);
      border:1px solid rgba(122,162,219,.32);
      border-radius:6px;
      padding:2px 6px;
      overflow-wrap:anywhere;
    }
    .eq-insight{
      margin-top:7px;
      border:1px solid rgba(122,162,219,.30);
      border-radius:10px;
      background:rgba(245,249,255,.58);
      padding:8px;
    }
    .eq-insight h2{
      margin:0 0 6px 0;
      color:#2f4f79;
      font:700 20px/1.08 var(--sans);
      letter-spacing:.01em;
    }
    .eq-insight-grid{
      display:grid;
      grid-template-columns:220px 1fr;
      gap:10px;
      align-items:start;
    }
    .eq-mini-svg{
      width:100%;
      height:108px;
      border:1px solid rgba(122,162,219,.30);
      border-radius:8px;
      background:rgba(255,255,255,.88);
      display:block;
    }
    .eq-mini-img{
      width:100%;
      height:108px;
      border:1px solid rgba(122,162,219,.30);
      border-radius:8px;
      background:rgba(255,255,255,.96);
      display:block;
      object-fit:cover;
      object-position:center;
      padding:0;
    }
    .eq-mini-canvas{
      width:100%;
      height:108px;
      border:1px solid rgba(122,162,219,.30);
      border-radius:8px;
      background:linear-gradient(180deg, rgba(248,252,255,.96), rgba(234,244,255,.9));
      display:block;
    }
    .eq-insight p{
      margin:0;
      color:#4a5d78;
      font-size:12px;
      line-height:1.45;
    }
    .eq-insight p strong{
      color:#32537d;
      font-weight:700;
    }
    .eq .sym.sym-spot{
      color:#3f2f1e;
      font:700 14px/1.45 "Times New Roman", Georgia, serif;
      letter-spacing:.01em;
      background:rgba(255,255,255,.96);
      border-radius:6px;
      padding:2px 6px;
      width:fit-content;
    }
    .eq-graph-card p code,
    .exec.eq-walk li code{
      background:rgba(255,255,255,.96);
      border-radius:4px;
      padding:0 4px;
    }
    .diag{
      margin:12px 0 16px;
      padding:12px 14px;
      border:1px solid rgba(86,129,196,.22);
      border-radius:12px;
      background:transparent;
    }
    .diag .kicker{
      margin:0 0 10px 0;
      color:#3f5f8e;
      font:700 11px/1 var(--mono);
      letter-spacing:.08em;
      text-transform:uppercase;
    }
    .diag .diag-toolbar{
      display:flex;
      gap:8px;
      margin-bottom:10px;
      flex-wrap:wrap;
      align-items:center;
    }
    .diag .diag-tab{
      border:1px solid rgba(86,129,196,.42);
      background:rgba(255,255,255,.72);
      color:#33557f;
      border-radius:999px;
      padding:5px 10px;
      font:700 10px/1 var(--mono);
      letter-spacing:.05em;
      text-transform:uppercase;
      cursor:pointer;
    }
    .diag .diag-tab.is-active{
      background:linear-gradient(180deg, rgba(66,136,230,.22) 0%, rgba(152,128,236,.18) 100%);
      border-color:rgba(66,136,230,.62);
      color:#1f3f67;
    }
    .diag .diag-action{
      border:1px solid rgba(86,129,196,.34);
      background:rgba(255,255,255,.74);
      color:#33557f;
      border-radius:999px;
      padding:5px 9px;
      font:700 10px/1 var(--mono);
      letter-spacing:.03em;
      text-transform:uppercase;
      cursor:pointer;
    }
    .diag .diag-action[data-diag-action="large"].is-active{
      background:linear-gradient(180deg, rgba(66,136,230,.22) 0%, rgba(152,128,236,.18) 100%);
      border-color:rgba(66,136,230,.62);
      color:#1f3f67;
    }
    .diag .diag-zoom-readout{
      color:#3f5f8e;
      font:700 10px/1 var(--mono);
      letter-spacing:.04em;
      text-transform:uppercase;
    }
    .diag .diag-board{
      display:none;
      border:1px solid rgba(98,145,215,.3);
      background:#ffffff;
      border-radius:10px;
      padding:0;
      overflow:hidden;
      position:relative;
    }
    .diag .diag-board.is-active{
      display:block;
    }
    .diag .diag-board .diag-svg{
      transform-origin:top left;
    }
    .diag .diag-board-controls{
      display:flex;
      align-items:center;
      gap:6px;
      background:rgba(255,255,255,.88);
      border:1px solid rgba(98,145,215,.32);
      border-radius:999px;
      padding:4px 6px;
      backdrop-filter:blur(1px);
      -webkit-backdrop-filter:blur(1px);
    }
    .diag .diag-board-header{
      display:flex;
      justify-content:flex-end;
      padding:8px 8px 0 8px;
      position:relative;
      z-index:2;
    }
    .diag .diag-board-scroll{
      padding:8px;
      overflow:auto;
      max-height:420px;
      min-height:320px;
      position:relative;
    }
    .diag .diag-backdrop{
      display:none;
      position:fixed;
      inset:0;
      background:rgba(21,36,61,.24);
      z-index:58;
    }
    .diag.is-large .diag-backdrop{
      display:block;
    }
    .diag.is-large .diag-board.is-active{
      position:fixed;
      inset:5vh 4vw;
      z-index:59;
      background:#ffffff;
      box-shadow:0 18px 42px rgba(23,40,67,.24);
      overflow:hidden;
      cursor:grab;
      touch-action:none;
      user-select:none;
      -webkit-user-select:none;
      display:flex;
      flex-direction:column;
    }
    .diag.is-large .diag-board.is-active.is-dragging{
      cursor:grabbing;
    }
    .diag .diag-svg{
      width:100%;
      min-width:660px;
      height:auto;
      display:block;
      cursor:zoom-in;
    }
    .diag.is-large .diag-board.is-active .diag-svg{
      cursor:inherit;
    }
    .diag.is-large .diag-board.is-active .diag-board-scroll{
      flex:1;
      max-height:none;
      min-height:0;
    }
    .diag .diag-node{
      fill:#f2f7ff;
      stroke:rgba(79,130,201,.58);
      stroke-width:1.2;
      rx:8;
      ry:8;
    }
    .diag .diag-zone{
      fill:rgba(255,255,255,.96);
      stroke:rgba(96,143,208,.32);
      stroke-width:1;
      rx:10;
      ry:10;
    }
    .diag .diag-zone-label{
      fill:#3f618f;
      font:700 9px/1 var(--mono);
      letter-spacing:.08em;
      text-transform:uppercase;
    }
    .diag .diag-cp-node{
      fill:rgba(255,255,255,.9);
      stroke:rgba(80,130,199,.56);
      stroke-width:1.1;
      rx:8;
      ry:8;
    }
    .diag .diag-cp-edge{
      stroke:rgba(70,124,194,.72);
      stroke-width:1.3;
      fill:none;
      marker-end:url(#diagArrow);
    }
    .diag .diag-cp-link{
      stroke:rgba(70,124,194,.5);
      stroke-width:1.1;
      fill:none;
      stroke-dasharray:4 3;
      marker-end:url(#diagArrow);
    }
    .diag .diag-node.core{
      fill:#e4f0ff;
      stroke:rgba(56,108,175,.84);
      stroke-width:1.45;
    }
    .diag .diag-edge{
      stroke:rgba(89,142,210,.64);
      stroke-width:1.45;
      fill:none;
      marker-end:url(#diagArrow);
    }
    .diag .diag-edge.core{
      stroke:rgba(56,108,175,.88);
      stroke-width:1.8;
    }
    .diag .diag-label{
      fill:#223f66;
      font:700 10.5px/1.2 var(--mono);
    }
    .diag .diag-label.small{
      fill:#43648f;
      font:600 9.3px/1.2 var(--mono);
    }
    .diag .diag-label.meta{
      fill:#53759f;
      font:600 8.4px/1.2 var(--mono);
    }
    .diag .diag-stage-columns{
      margin:10px 0 0;
      display:grid;
      grid-template-columns:repeat(4,minmax(0,1fr));
      gap:8px;
      align-items:start;
    }
    .diag .diag-stage-lane{
      display:grid;
      gap:7px;
    }
    .diag .diag-stage-lane.trace-lane{
      grid-column:1 / -1;
      grid-template-columns:repeat(3,minmax(220px,1fr));
      align-items:start;
    }
    .diag .diag-stage-lane.trace-lane .lane-kicker{
      grid-column:1 / -1;
      margin:0;
    }
    .diag .diag-stage-lane .lane-kicker{
      margin:0;
      color:#365983;
      font:700 10px/1 var(--mono);
      letter-spacing:.07em;
      text-transform:uppercase;
      padding:4px 6px;
      border:1px solid rgba(98,145,215,.32);
      border-radius:7px;
      background:rgba(255,255,255,.78);
    }
    .diag .diag-stage-col{
      border:1px solid rgba(98,145,215,.34);
      border-radius:9px;
      padding:7px 8px;
      background:rgba(255,255,255,.8);
    }
    .diag .diag-stage-col.core{
      background:rgba(226,239,255,.9);
      border-color:rgba(56,108,175,.56);
    }
    .diag .diag-stage-col.audit{
      background:rgba(235,238,255,.92);
      border-color:rgba(94,106,184,.52);
    }
    .diag .diag-stage-col h6{
      margin:0 0 5px 0;
      color:#213e65;
      font:700 10px/1.25 var(--mono);
      letter-spacing:.02em;
      text-transform:uppercase;
    }
    .diag .diag-stage-col dl{
      margin:0;
      display:grid;
      gap:3px;
    }
    .diag .diag-stage-col dl > div{
      display:grid;
      grid-template-columns:28px 1fr;
      gap:5px;
    }
    .diag .diag-stage-col dt{
      margin:0;
      color:#4f74a5;
      font:700 9px/1.25 var(--mono);
      text-transform:uppercase;
    }
    .diag .diag-stage-col dd{
      margin:0;
      color:#2f4567;
      font:600 9px/1.25 var(--mono);
    }
    .diag .diag-stage-col .key-row{
      margin-top:4px;
      padding-top:4px;
      border-top:1px dashed rgba(98,145,215,.36);
    }
    .diag .diag-stage-col .risk-row dt{
      color:#7d3f36;
    }
    .diag .diag-stage-col .gate-row dt{
      color:#3f5f35;
    }
    .diag .mermaid-src{
      margin:8px 0 0;
      border:1px solid rgba(98,145,215,.32);
      border-radius:8px;
      background:rgba(255,255,255,.86);
      padding:8px;
      color:#2f4567;
      font:600 10px/1.38 var(--mono);
      overflow:auto;
      white-space:pre;
    }
    .diag .diag-data-grid{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(230px,1fr));
      gap:8px;
    }
    .diag .diag-data-card{
      border:1px solid rgba(98,145,215,.34);
      border-radius:10px;
      background:rgba(255,255,255,.86);
      padding:8px;
    }
    .diag .diag-data-card.core{
      border-color:rgba(56,108,175,.56);
      background:rgba(226,239,255,.9);
    }
    .diag .diag-data-head{
      display:flex;
      align-items:center;
      gap:6px;
      margin-bottom:6px;
    }
    .diag .diag-data-head .idx{
      display:inline-flex;
      min-width:20px;
      height:20px;
      align-items:center;
      justify-content:center;
      border-radius:999px;
      background:rgba(66,136,230,.2);
      color:#2f5788;
      font:700 10px/1 var(--mono);
    }
    .diag .diag-data-card.core .idx{
      background:rgba(56,108,175,.28);
      color:#22456e;
    }
    .diag .diag-data-head h5{
      margin:0;
      color:#213e65;
      font:700 11px/1.3 var(--mono);
    }
    .diag .diag-data-card dl{
      margin:0;
      display:grid;
      gap:4px;
    }
    .diag .diag-data-card dl > div{
      display:grid;
      grid-template-columns:66px 1fr;
      gap:6px;
    }
    .diag .diag-data-card dt{
      margin:0;
      color:#4f74a5;
      font:700 10px/1.3 var(--mono);
      text-transform:uppercase;
    }
    .diag .diag-data-card dd{
      margin:0;
      color:#2f4567;
      font:600 10px/1.3 var(--mono);
    }
    .diag .diag-data-extra{
      margin-top:6px;
      padding-top:6px;
      border-top:1px dashed rgba(98,145,215,.36);
      color:#2f4567;
      font:600 10px/1.35 var(--mono);
    }
    @media(max-width:720px){
      .diag .diag-svg{
        min-width:560px;
      }
      .diag .diag-stage-columns{
        grid-template-columns:1fr;
      }
      .diag .diag-stage-lane.trace-lane{
        grid-template-columns:1fr;
      }
    }
    .rail{
      position:sticky;
      top:10px;
      border:none;
      border-radius:12px;
      background:transparent;
      padding:12px;
      box-shadow:none;
    }
    .rail h3{margin:0 0 8px 0;font-size:14px;color:#4a3d2e}
    .kv{display:grid;grid-template-columns:100px 1fr;gap:6px 8px;font:600 11px/1.45 var(--mono);color:#6b6155}
    .kv b{color:var(--accent)}
    details{
      margin-top:8px;
      border:none;
      border-radius:10px;
      background:transparent;
      overflow:hidden;
    }
    summary{
      cursor:pointer;
      list-style:none;
      padding:8px 10px;
      font:700 11px/1.3 var(--mono);
      color:#4c3f31;
      display:flex;
      align-items:center;
      justify-content:space-between;
    }
    summary::after{content:"+";color:var(--accent)}
    details[open] summary::after{content:"−"}
    .d-body{padding:0 10px 9px;color:#655b4f;font-size:12px;line-height:1.45}
    .refs{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:8px;
    }
    .ref{
      border:none;
      background:transparent;
      border-radius:10px;
      padding:8px;
      font-size:12px;
      color:#665d51;
    }
    .eq-graph-grid{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:10px;
      margin:10px 0 12px;
    }
    .eq-graph-card{
      border:1px solid rgba(141,111,255,.26);
      background:rgba(255,255,255,.48);
      border-radius:10px;
      padding:9px 10px;
    }
    .eq-graph-card h4{
      margin:0 0 6px;
      color:#3a2f53;
      font:700 12px/1.25 var(--mono);
      letter-spacing:.02em;
      text-transform:uppercase;
    }
    .eq-graph-card p{
      margin:0;
      font-size:12px;
      line-height:1.45;
      color:#564a6d;
    }
    .candle-board{
      border:1px solid rgba(122,162,219,.38);
      border-radius:10px;
      padding:8px 10px 9px;
      background:rgba(247,251,255,.68);
      margin-top:8px;
    }
    .candle-kicker{
      margin:0 0 8px;
      color:#3c5c87;
      font:700 10px/1 var(--mono);
      letter-spacing:.07em;
      text-transform:uppercase;
    }
    .candle-row{
      display:grid;
      grid-template-columns:repeat(6,minmax(0,1fr));
      gap:8px;
      align-items:end;
      min-height:120px;
    }
    .candle{
      position:relative;
      height:112px;
      border-radius:6px;
      background:linear-gradient(180deg, rgba(255,255,255,.16) 0%, rgba(255,255,255,0) 100%);
      border:1px solid rgba(122,162,219,.18);
    }
    .candle::before{
      content:"";
      position:absolute;
      left:50%;
      width:2px;
      margin-left:-1px;
      bottom:8px;
      height:var(--wick,72px);
      background:linear-gradient(180deg, rgba(136,171,228,.9) 0%, rgba(136,171,228,.55) 100%);
      border-radius:2px;
    }
    .candle::after{
      content:"";
      position:absolute;
      left:50%;
      width:16px;
      margin-left:-8px;
      bottom:var(--body-bottom,20px);
      height:var(--body-height,36px);
      border-radius:3px;
      background:linear-gradient(180deg, rgba(89,141,214,.96) 0%, rgba(124,107,226,.92) 100%);
      box-shadow:0 1px 6px rgba(90,124,198,.25);
    }
    .candle-label{
      display:block;
      margin-top:4px;
      text-align:center;
      color:#5776a3;
      font:700 9px/1 var(--mono);
    }
    .eq-matrix{
      margin:10px 0 14px;
      border:1px solid rgba(141,111,255,.22);
      border-radius:12px;
      background:rgba(255,255,255,.44);
      padding:10px;
      position:relative;
      overflow:hidden;
    }
    .eq-matrix-bloch{
      position:absolute;
      inset:0;
      width:100%;
      height:100%;
      pointer-events:none;
      opacity:.45;
      z-index:0;
    }
    .eq-matrix-head{
      margin:0 0 8px;
      color:#3b3156;
      font:700 11px/1 var(--mono);
      letter-spacing:.07em;
      text-transform:uppercase;
      position:relative;
      z-index:1;
    }
    .eq-matrix-note{
      margin:0 0 10px;
      color:#5b4f74;
      font-size:12px;
      line-height:1.45;
      position:relative;
      z-index:1;
    }
    .eq-matrix-grid{
      display:grid;
      grid-template-columns:repeat(3,minmax(0,1fr));
      gap:10px;
      position:relative;
      z-index:1;
    }
    .eq-matrix-card{
      border:1px solid rgba(122,162,219,.32);
      border-radius:10px;
      background:rgba(249,252,255,.76);
      overflow:hidden;
    }
    .eq-matrix-card.controls{
      grid-column:1 / -1;
      padding:9px 10px 10px;
      background:rgba(247,251,255,.84);
    }
    .eq-live-plot{
      display:block;
      width:100%;
      height:136px;
      background:#eef3fb;
    }
    .eq-live-fallback{
      display:block;
      width:100%;
      height:136px;
      object-fit:cover;
      background:#eef3fb;
      animation:eqPlotFloat 6.8s ease-in-out infinite;
    }
    @keyframes eqPlotFloat{
      0%{transform:translateY(0) scale(1)}
      50%{transform:translateY(-2px) scale(1.004)}
      100%{transform:translateY(0) scale(1)}
    }
    .eq-matrix-card{
      animation:eqPlotFloat 7.2s ease-in-out infinite;
    }
    .eq-matrix-card:nth-child(2n){animation-duration:8.1s}
    .eq-matrix-card:nth-child(3n){animation-duration:9.3s}
    .eq-matrix-card:nth-child(4n){animation-duration:10.2s}
    .eq-matrix-grid:hover .eq-matrix-card{
      animation-duration:6s;
    }
    .eq-matrix-link-mode{
      margin:0 0 10px;
      color:#4a6389;
      font:600 10px/1.35 var(--mono);
      letter-spacing:.03em;
      text-transform:uppercase;
      position:relative;
      z-index:1;
    }
    .eq-matrix-link-mode code{
      display:inline-block;
      margin-left:6px;
      padding:2px 6px;
      border-radius:999px;
      border:1px solid rgba(96,132,190,.35);
      background:rgba(255,255,255,.75);
      color:#314d78;
      font:700 10px/1 var(--mono);
    }
    .eq-matrix-options{
      margin:6px 0 0;
      display:flex;
      gap:6px;
      flex-wrap:wrap;
      position:relative;
      z-index:1;
    }
    .eq-matrix-opt{
      border:1px solid rgba(96,132,190,.35);
      background:rgba(255,255,255,.72);
      color:#33557f;
      border-radius:999px;
      padding:4px 8px;
      font:700 10px/1 var(--mono);
      letter-spacing:.03em;
      text-transform:uppercase;
      cursor:pointer;
    }
    .eq-matrix-options.inline{
      margin-top:7px;
      justify-content:flex-start;
    }
    .eq-matrix-opt.is-active{
      background:linear-gradient(180deg, rgba(66,136,230,.22) 0%, rgba(152,128,236,.18) 100%);
      border-color:rgba(66,136,230,.62);
      color:#1f3f67;
    }
    .eq-matrix-opt[disabled]{
      opacity:.45;
      cursor:not-allowed;
    }
    .eq-matrix-card .meta{
      padding:8px 9px 9px;
    }
    .eq-matrix-card .meta-top{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:8px;
      margin-bottom:4px;
    }
    .eq-matrix-card .meta b{
      display:block;
      margin:0;
      color:#35527b;
      font:700 10px/1.25 var(--mono);
      letter-spacing:.03em;
      text-transform:uppercase;
    }
    .eq-matrix-card .meta span{
      display:block;
      color:#536989;
      font:600 10px/1.35 var(--mono);
    }
    .status-chip{
      display:inline-flex;
      align-items:center;
      border-radius:999px;
      padding:2px 7px;
      font:700 9px/1 var(--mono);
      letter-spacing:.04em;
      text-transform:uppercase;
      border:1px solid transparent;
      white-space:nowrap;
    }
    .status-chip.draft{
      color:#7b5b2b;
      background:rgba(214,166,85,.17);
      border-color:rgba(214,166,85,.34);
    }
    .status-chip.validated{
      color:#2f5f40;
      background:rgba(103,187,136,.16);
      border-color:rgba(103,187,136,.34);
    }
    .status-chip.published{
      color:#325a8d;
      background:rgba(103,159,226,.16);
      border-color:rgba(103,159,226,.34);
    }
    .ref a{color:#7a5a33;text-decoration:none}
    .ref a:hover{text-decoration:underline}
    .cta{
      margin-top:14px;
      display:flex;
      flex-wrap:wrap;
      gap:8px;
    }
    .btn{
      border:none;
      border-radius:10px;
      padding:8px 10px;
      color:#4b3b2a;
      text-decoration:none;
      font:600 12px/1 var(--mono);
      background:transparent;
    }
    .btn:hover{border-color:#9c7a4f}
    .foot{margin-top:12px;color:#7b6f61;font-size:11px}
    @media(max-width:1020px){
      .layout{grid-template-columns:1fr}
      .rail{position:relative;top:auto}
      .refs{grid-template-columns:1fr}
      .eq-graph-grid{grid-template-columns:1fr}
      .eq-matrix-grid{grid-template-columns:repeat(2,minmax(0,1fr))}
      .eq-insight-grid{grid-template-columns:1fr}
    }
    @media(max-width:760px){
      :root{
        --hero-badge-max-width:252px;
        --hero-badge-padding-y:7px;
        --hero-badge-padding-x:9px;
      }
      .top-menu{
        align-items:flex-start;
        flex-direction:column;
        gap:8px;
        padding:8px 8px;
        margin:0 calc(50% - 50vw) 8px;
      }
      .top-menu .items{
        justify-content:flex-start;
        gap:5px;
      }
      .top-menu .items a{
        font-size:9px;
        padding:5px 7px;
      }
      .paper{
        padding:12px 10px 14px;
      }
      .paper h2{
        font-size:22px;
      }
      .eq{
        padding:6px 6px;
      }
      .eq .sym{
        font-size:12px;
      }
      .eq .plain{
        font-size:10px;
      }
      .eq .eq-link,
      .exec .exec-eq-link{
        font-size:9px;
      }
      .exec .exec-eq-top,
      .exec .exec-eq-link,
      .eq .sym,
      .eq .plain,
      .eq .eq-link{
        display:block;
        width:100%;
        max-width:100%;
      }
      .eq-matrix-grid{grid-template-columns:1fr}
    }
    @media(max-width:520px){
      .page{
        padding:14px 8px 38px;
      }
      .top-menu{
        padding:7px 6px;
      }
      .top-menu .brand{
        font-size:9px;
      }
      .top-menu .items a{
        font-size:8px;
        padding:4px 6px;
      }
      .title{
        font-size:clamp(22px,8vw,36px);
      }
      .subtitle{
        font-size:12px;
      }
      .exec{
        padding:10px 9px;
      }
      .exec ul{
        padding-left:16px;
      }
      .eq .sym{
        font-size:11px;
      }
      .eq .plain{
        font-size:9px;
      }
      .eq .eq-link,
      .exec .exec-eq-link{
        font-size:8px;
      }
      .eq-insight{
        padding:7px;
      }
      .eq-insight h2{
        font-size:18px;
      }
      .eq-insight p{
        font-size:11px;
      }
    }
    @media (prefers-reduced-motion: reduce){
      .reactive-dots{display:none;}
      body::before,
      body::after{animation:none;}
      .eq-live-fallback,
      .eq-matrix-card{animation:none;}
    }
  </style>
</head>
<body>
  <main class="page">
    <canvas id="dots-layer" class="reactive-dots" aria-hidden="true"></canvas>
    <nav class="top-menu" aria-label="Primary section menu">
      <span class="brand">ugrad.ai / qbitos.ai</span>
      <div class="items">
        <a href="#summary">Summary</a>
        <a href="#equations">Equations</a>
        <a href="#evidence">Evidence</a>
        <a href="#targets">Targets</a>
      </div>
    </nav>
    <header class="hero">
      <p class="eyebrow">Launch Paper | ugrad.ai × qbitos.ai</p>
      <h1 class="title">Quantum-Centric Communication<br>Cycle for Cross-App Intelligence</h1>
      <p class="subtitle">A publish-ready landing paper defining the Μμ macro/micro model,<br>derived equation stack, retrieval-memory loop, and production pathway<br>for a cross-platform .qhtml / PWA research surface.</p>
      <div class="brand-row">
        <span class="pill">UGRAD.AI MAIN LANDING</span>
        <span class="pill">QBITOS.AI LAUNCHING SOON DUPLICATE</span>
        <span class="pill">PWA-READY .QHTML FORMAT</span>
      </div>
    </header>

    <section class="layout">
      <article class="paper">
        <h2 id="summary">Executive Summary</h2>
        <p>This paper defines a practical architecture for cross-app intelligence where one communication cycle controls authoring, execution, verification, and reuse across browser PWAs and quantum backends.</p>
        <section class="exec" aria-label="Quick review points">
          <p class="exec-eq-top">|ψ<sub>out</sub>⟩ = (E ∘ R ∘ D ∘ T)(|ψ<sub>in</sub>⟩), &nbsp; T=Detect, D=Decode, R=Render, E=Enhance</p>
          <p class="exec-eq-link">Pipeline State Evolution · Use chart lane only when stage timing/fidelity deltas change; otherwise equation-only review is sufficient.</p>
          <p class="kicker">What A Reviewer Sees Fast</p>
          <ul>
            <li><strong>Core thesis:</strong> macro orchestration (Μ) emerges from coordinated micro operators (μ) across a repeatable Detect → Decode → Render → Enhance cycle.</li>
            <li><strong>Production path:</strong> overclocked local source → prefix/gutter + steno + `.qbit` encode → preflight constraints → QPU dispatch → validation → memory reinjection.</li>
            <li><strong>Robustness claim:</strong> round-trip fidelity and formatter-safe strip/reinject provide durable artifact integrity and reproducible handoffs.</li>
            <li><strong>Operational value:</strong> faster iteration, clearer traceability, and lower deployment ambiguity for research-to-runtime workflows.</li>
          </ul>
        </section>
        <div class="diag" aria-label="Communication cycle from authoring to QPU and memory reinjection">
          <p class="kicker">Communication Cycle Diagram</p>
          <div class="diag-toolbar" role="tablist" aria-label="Diagram view mode">
            <button class="diag-tab is-active" type="button" data-diag-view="blocks" aria-pressed="true">Block View</button>
            <button class="diag-tab" type="button" data-diag-view="data" aria-pressed="false">Data Fields</button>
          </div>
          <div class="diag-backdrop" data-diag-backdrop aria-hidden="true"></div>

          <div class="diag-board is-active" data-diag-panel="blocks">
            <div class="diag-board-header">
              <div class="diag-board-controls" aria-label="Diagram controls">
                <button class="diag-action" type="button" data-diag-action="zoom-out">Zoom -</button>
                <button class="diag-action" type="button" data-diag-action="zoom-in">Zoom +</button>
                <button class="diag-action" type="button" data-diag-action="zoom-reset">Reset</button>
                <span class="diag-zoom-readout" data-diag-zoom-readout>100%</span>
              </div>
            </div>
            <div class="diag-board-scroll">
            <svg class="diag-svg" viewBox="0 0 980 540" role="img" aria-label="Block diagram showing control plane overlay and runtime flow from authoring to DAC core, quantum gutter prefixes, qbit encode, and memory reinjection">
              <defs>
                <marker id="diagArrow" viewBox="0 0 10 10" refX="8.3" refY="5" markerWidth="5.6" markerHeight="5.6" orient="auto-start-reverse">
                  <path d="M0,0 L10,5 L0,10 z" fill="rgba(56,108,175,.88)"></path>
                </marker>
              </defs>

              <rect class="diag-zone" x="12" y="10" width="956" height="96"></rect>
              <text class="diag-zone-label" x="24" y="30">CONTROL PLANE OVERLAY</text>
              <text class="diag-label meta" x="24" y="45">Users → Agents → Models / MCPs / Servers → runtime flow → user feedback</text>

              <rect class="diag-cp-node" x="24" y="56" width="126" height="34"></rect>
              <text class="diag-label small" x="35" y="77">Users</text>
              <rect class="diag-cp-node" x="164" y="56" width="126" height="34"></rect>
              <text class="diag-label small" x="176" y="77">Agents (L2)</text>
              <rect class="diag-cp-node" x="304" y="56" width="136" height="34"></rect>
              <text class="diag-label small" x="316" y="77">Models</text>
              <rect class="diag-cp-node" x="454" y="56" width="116" height="34"></rect>
              <text class="diag-label small" x="466" y="77">MCPs</text>
              <rect class="diag-cp-node" x="584" y="56" width="142" height="34"></rect>
              <text class="diag-label small" x="596" y="77">Servers</text>

              <path class="diag-cp-edge" d="M150 73 H164"></path>
              <path class="diag-cp-edge" d="M290 73 H304"></path>
              <path class="diag-cp-edge" d="M440 73 H454"></path>
              <path class="diag-cp-edge" d="M570 73 H584"></path>

              <rect class="diag-zone" x="12" y="118" width="956" height="408"></rect>
              <text class="diag-zone-label" x="24" y="138">RUNTIME FLOW (01–11 SURFACE, CORE NODES SHOWN)</text>

              <rect class="diag-node" x="18" y="144" width="180" height="108"></rect>
              <text class="diag-label" x="30" y="168">01 Authoring / Intent</text>
              <text class="diag-label small" x="30" y="186">Prompt + corpus + Contrails</text>
              <text class="diag-label meta" x="30" y="206">IN: Prompt + context corpus</text>
              <text class="diag-label meta" x="30" y="220">TG: &lt;100ms intent normalize</text>
              <text class="diag-label meta" x="30" y="234">OUT: Structured run payload</text>

              <rect class="diag-node" x="222" y="144" width="180" height="108"></rect>
              <text class="diag-label" x="234" y="168">02 Iron Line L0-L7</text>
              <text class="diag-label small" x="234" y="186">Deterministic stage routing</text>
              <text class="diag-label meta" x="234" y="206">IN: Run payload + stage map</text>
              <text class="diag-label meta" x="234" y="220">TG: Deterministic layer route</text>
              <text class="diag-label meta" x="234" y="234">OUT: Stage ownership envelope</text>
              <text class="diag-label meta" x="234" y="248">MCP bridge: tool/resource adapters</text>

              <rect class="diag-node core" x="428" y="144" width="210" height="116"></rect>
              <text class="diag-label" x="442" y="169">03 DAC Tracks + Stripes</text>
              <text class="diag-label small" x="442" y="188">Structural observability core</text>
              <text class="diag-label meta" x="442" y="209">IN: Source lines + language</text>
              <text class="diag-label meta" x="442" y="223">TG: Sortable structural telemetry</text>
              <text class="diag-label meta" x="442" y="237">OUT: sym/gate/depth/category</text>
              <text class="diag-label meta" x="442" y="251">KEY: track/tokenType/contextScore</text>

